# Database Configuration
# Use postgresql+asyncpg for async SQLAlchemy operations
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/listings_db

# Groq LLM Configuration
# To run end-to-end, insert your Groq API key.
# If left empty, the application falls back to a rule-based mock extractor.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
