# Database Configuration
# By default, if DATABASE_URL is not set, the app will automatically use SQLite locally.
# If you want to use a local PostgreSQL database, uncomment the line below and modify as needed:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/listings_db

# Groq LLM Configuration
# Optional: To run live LLM parsing, insert your Groq API key.
# If left empty, the application falls back to a rule-based mock extractor.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
